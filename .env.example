# =============================================================================
# 环境变量示例（设计文档 12：提供 .env.example）
# 用法：cp .env.example .env，再按需修改。本地最小运行无需任何模型 key
#       （EMBEDDING_PROVIDER=mock + LLM_PROVIDER=mock 即可跑通全链路 smoke-test）。
# =============================================================================

# ---- 基础 ----
DOMAIN=localhost
FRONTEND_HOST=http://localhost:5173
ENVIRONMENT=local
PROJECT_NAME="企业知识库AI助手后端"
STACK_NAME=enterprise-kb-rag-agent-backend
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,http://localhost:5174,http://localhost:8000"
SECRET_KEY=changethis
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# ---- Postgres (pgvector) ----
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# ---- Redis（限流 / 缓存）----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
RATE_LIMIT_PER_MINUTE=30

# ---- Embedding ----
# mock：无需 key，确定性伪向量，便于本地 smoke-test；openai：真实 embedding
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ---- LLM ----
# mock：无需 key；openai / claude：填入对应 key
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini
LLM_FALLBACK_MODEL=
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=

# ---- RAG 参数 ----
RETRIEVAL_TOP_K=4
RETRIEVAL_CANDIDATE_K=20
RRF_K=60
RERANK_ENABLED=True
RERANK_MODEL=BAAI/bge-reranker-base
# mock 模式下设为 0.0 关闭拒答；生产环境建议 0.3
REFUSAL_THRESHOLD=0.0

# ---- Agent ----
AGENT_MAX_STEPS=5

# ---- Langfuse 可观测（可选）----
LANGFUSE_ENABLED=False
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ---- 邮件（模板遗留，可留空）----
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

SENTRY_DSN=
